# DriveLink Environment Variables
# Copy this file to .env and fill in your values

# Port to run the server on (default: 3000)
PORT=3000

# Your production domain (used in short URLs)
# Example: https://drivelink.io
BASE_URL=http://localhost:3000

# Path to SQLite database file (default: ./db/links.db)
DB_PATH=./db/links.db
